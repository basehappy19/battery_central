datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Device {
  id               String       @id @default(uuid())
  name             String
  platform         String       // e.g., "Windows", "iOS", "Android", "ESP32"
  batteryLevel     Int          // 0-100
  isCharging       Boolean
  prevBattery      Int?         // Previous battery level for rate calculation
  prevUpdatedAt    DateTime?    // Previous update timestamp for rate calculation
  timeRemaining    Int?         // Estimated minutes remaining (to full or empty)
  acceptingUpdates Boolean      @default(true) // Enable/disable receiving requests
  order            Int          @default(0)    // Display order on dashboard
  updatedAt        DateTime     @updatedAt
  logs             BatteryLog[]
}

model BatteryLog {
  id           String   @id @default(uuid())
  deviceId     String
  device       Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  batteryLevel Int
  isCharging   Boolean
  eventType    String   // e.g., "PLUGGED_IN", "UNPLUGGED", "LEVEL_UPDATE", "INITIAL"
  createdAt    DateTime @default(now())

  @@index([deviceId, createdAt])
}

model Setting {
  key   String @id
  value String
}

model ApiLog {
  id           String   @id @default(uuid())
  method       String   // "GET", "POST", "PATCH", "DELETE"
  path         String   // e.g., "/api/battery/update"
  status       Int      // e.g., 200, 400, 401, 500
  durationMs   Int      // Execution time in milliseconds
  ip           String?  // Source IP or identifier
  userAgent    String?  // e.g., "MacroDroid", "Tasker", "ESP32", "Mozilla/5.0"
  requestBody  String?  // JSON string of request body or query params
  responseBody String?  // JSON string of response payload
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([path, status])
}
